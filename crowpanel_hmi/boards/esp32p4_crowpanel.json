{
  "build": {
    "arduino": {
      "ldscript": "esp32p4_out.ld"
    },
    "core": "esp32",
    "cpu": "esp32p4",
    "extra_flags": "-DARDUINO_ESP32P4_DEV",
    "f_cpu": "360000000L",
    "f_flash": "80000000L",
    "flash_mode": "dio",
    "hwids": [["0x10c4", "0xeb70"]],
    "mcu": "esp32p4",
    "variant": "esp32p4"
  },
  "connectivity": ["wifi", "ble"],
  "debug": {
    "default_tool": "esp-prog",
    "onboard_tools": ["esp-prog"],
    "protocols": ["jtag"]
  },
  "frameworks": ["arduino", "esp-idf"],
  "name": "CrowPanel ESP32-P4",
  "upload": {
    "espflash": {
      "extra_baudrate": 115200
    },
    "flash_size": "16MB",
    "maximum_ram_size": 786432,
    "maximum_size": 16777216,
    "protocol": "esp-idf",
    "protocols": ["esptool", "jtag"],
    "speed": 460800
  },
  "url": "https://github.com/elecfreaks/crowpanel",
  "vendor": "Elecfreaks"
}
