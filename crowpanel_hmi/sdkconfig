#
# CrowPanel 7" ESP32-P4 HMI Display Configuration
# Generated configuration - customize via "idf.py menuconfig" in VSCode
#

# SDK Configuration
CONFIG_IDF_TARGET="esp32p4"
CONFIG_IDF_TARGET_ESP32P4=y

# Memory allocation
CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_HEX=0
CONFIG_SPIRAM_TYPE_AUTO=y

# PSRAM for display buffer
CONFIG_SPIRAM_MALLOC_ALWAYSINTERNAL=262144

# Serial configuration
CONFIG_ESP_CONSOLE_UART0=y
CONFIG_ESP_CONSOLE_UART_BAUDRATE=115200

# LVGL configuration
CONFIG_LV_CONF_INCLUDE_SIMPLE=y

# Task configuration  
CONFIG_ESP_TASK_WDT_TIMEOUT_S=60
CONFIG_ESP_TASK_WDT_INIT=y

# Partition table (16MB flash)
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions_16mb.csv"
CONFIG_PARTITION_TABLE_CUSTOM_APP_BIN_OFFSET=0x100000
CONFIG_PARTITION_TABLE_CUSTOM_APP_SIZE=0xF00000

